# ==================== BARIMA ROYAL SUITES BACKEND CONFIG ====================
# Copy this file to .env and fill in with your actual values

# ==================== DATABASE CONNECTION ====================
# Get this from Railway Dashboard -> Postgres Service -> Connection String
# It should look like: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://username:password@your-railway-host:5432/barima_royal_suites

# ==================== SERVER ====================
PORT=3000
NODE_ENV=production

# ==================== HOW TO GET DATABASE_URL FROM RAILWAY ====================
# 1. Go to Railway Dashboard (https://railway.app)
# 2. Select your Barima Royal Suites project
# 3. Click on PostgreSQL service
# 4. Go to "Connect" tab
# 5. Copy the connection string under "Postgres Connection"
# 6. Paste it as DATABASE_URL above
# 
# Example: 
# DATABASE_URL=postgresql://postgres:abc123@containers-us-west-123.railway.app:7890/railway
